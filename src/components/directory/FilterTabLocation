import { Tabs, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { getLocationRegion, LOCATION_REGIONS } from "@/lib/constants";

const TAB_ALL = "all";

const TAB_LABELS = {
  [TAB_ALL]: "All",
  North: "North",
  South: "South",
  East: "East",
  West: "West",
  Central: "Central",
  "North-East": "North-East",
};

function getActiveTab(locationFilter) {
  if (!locationFilter) return TAB_ALL;
  if (LOCATION_REGIONS.includes(locationFilter)) return locationFilter;
  return getLocationRegion(locationFilter) || TAB_ALL;
}

export default function FilterTabLocation({ locationFilter, onLocationChange }) {
  const activeTab = getActiveTab(locationFilter);

  return (
    <Tabs
      value={activeTab}
      onValueChange={(value) => {
        onLocationChange(value === TAB_ALL ? "" : value);
      }}
      className="w-full"
    >
      <TabsList className="grid w-full max-w-2xl mx-auto gap-0.5 h-auto p-1 grid-cols-3 sm:grid-cols-7">
        <TabsTrigger value={TAB_ALL} className="text-xs py-2 px-1">
          {TAB_LABELS[TAB_ALL]}
        </TabsTrigger>
        {LOCATION_REGIONS.map((region) => (
          <TabsTrigger key={region} value={region} className="text-xs py-2 px-1">
            {TAB_LABELS[region]}
          </TabsTrigger>
        ))}
      </TabsList>
    </Tabs>
  );
}
