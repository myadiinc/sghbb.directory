import { Tabs, TabsList, TabsTrigger } from "@/components/ui/tabs";
import { HALAL_OPTIONS } from "@/lib/constants";

const TAB_ALL = "all";

function getActiveTab(halalFilter) {
  if (!halalFilter) return TAB_ALL;
  if (HALAL_OPTIONS.includes(halalFilter)) return halalFilter;
  return TAB_ALL;
}

export default function FilterTabHalal({ halalFilter, onHalalChange }) {
  const activeTab = getActiveTab(halalFilter);

  return (
    <Tabs
      value={activeTab}
      onValueChange={(value) => {
        onHalalChange(value === TAB_ALL ? "" : value);
      }}
      className="w-full mt-3"
    >
      <TabsList className="grid w-full max-w-2xl mx-auto gap-0.5 h-auto p-1 grid-cols-3">
        <TabsTrigger value={TAB_ALL} className="text-xs py-2 px-1">
          All
        </TabsTrigger>
        {HALAL_OPTIONS.map((option) => (
          <TabsTrigger key={option} value={option} className="text-xs py-2 px-1">
            {option}
          </TabsTrigger>
        ))}
      </TabsList>
    </Tabs>
  );
}
